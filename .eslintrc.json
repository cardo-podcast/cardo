{
  "extends": "react-app",
  "plugins": [
    "react-refresh"
  ],
  // ...
  "rules": {
    "react-hooks/exhaustive-deps": 0,
    "react-refresh/only-export-components": "warn",
    "no-restricted-syntax": [
      "error",
      {
        "selector": "ImportDeclaration[specifiers.length=0]",
        "message": "Empty import"
      }
    ]
  }
}